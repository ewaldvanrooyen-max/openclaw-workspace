{
  "agents": {
    "defaults": {
      "workspace": "~/.pocketmind/workspace",
      "model": "anthropic/claude-sonnet-4-6",
      "provider": "openrouter",
      "max_tool_iterations": 20,
      "temperature": 0.7
    }
  },
  "providers": {
    "openrouter": {
      "apiKey": "sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    }
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "token": "YOUR_TELEGRAM_BOT_TOKEN",
      "allowFrom": ["YOUR_USER_ID"]
    }
  },
  "heartbeat": {
    "enabled": true,
    "interval": 30
  },
  "tools": {
    "exec": {
      "enabled": true,
      "timeout": 60
    },
    "web": {
      "brave": {
        "enabled": false,
        "apiKey": "YOUR_BRAVE_API_KEY"
      },
      "duckduckgo": {
        "enabled": true
      }
    }
  }
}
